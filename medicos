<script>
// SCROLL REVEAL
const reveals = document.querySelectorAll('.reveal');
const revealObs = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
reveals.forEach(el => revealObs.observe(el));

// STAGGER CARDS
document.querySelectorAll('.med-service, .pain-card, .ia-med-feature, .med-step').forEach((el, i) => {
  el.style.transitionDelay = `${i * 0.1}s`;
  el.classList.add('reveal');
  revealObs.observe(el);
});

// 3D TILT ON SERVICE CARDS
document.querySelectorAll('.med-service').forEach(card => {
  card.addEventListener('mousemove', (e) => {
    const r = card.getBoundingClientRect();
    const x = (e.clientX - r.left) / r.width - 0.5;
    const y = (e.clientY - r.top) / r.height - 0.5;
    card.style.transform = `translateY(-6px) scale(1.02) perspective(600px) rotateY(${x*5}deg) rotateX(${-y*5}deg)`;
  });
  card.addEventListener('mouseleave', () => { card.style.transform = ''; });
});

// FLOATING PARTICLES
const hero = document.querySelector('.med-hero');
if (hero) {
  for (let i = 0; i < 15; i++) {
    const p = document.createElement('div');
    const s = Math.random() * 3 + 1;
    p.style.cssText = `position:absolute;width:${s}px;height:${s}px;background:rgba(74,144,217,${Math.random()*0.3+0.1});border-radius:50%;pointer-events:none;z-index:1;left:${Math.random()*100}%;top:${Math.random()*100}%;animation:float ${Math.random()*4+3}s ${Math.random()*2}s ease-in-out infinite;`;
    hero.appendChild(p);
  }
}

// NAV SCROLL
window.addEventListener('scroll', () => {
  document.querySelector('nav').classList.toggle('scrolled', window.scrollY > 50);
});

// FAQ TOGGLE
document.querySelectorAll('.faq-item').forEach(item => {
  item.addEventListener('click', () => {
    const answer = item.querySelector('.faq-answer');
    const arrow = item.querySelector('.faq-arrow');
    const isOpen = answer.style.display === 'block';
    document.querySelectorAll('.faq-answer').forEach(a => a.style.display = 'none');
    document.querySelectorAll('.faq-arrow').forEach(a => a.textContent = '+');
    if (!isOpen) {
      answer.style.display = 'block';
      arrow.textContent = '−';
    }
  });
});
</script>

